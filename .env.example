# Tikin Dashboard — Environment Variables
# Copy this file to .env.local and fill in real values for local development.
# In production, configure these in the Vercel dashboard.
# NEVER commit .env.local — it contains secrets.

# === Auth (Plan 01) ===

# 32+ random chars used to sign session JWTs.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# bcrypt hash of the shared dashboard password (cost 10).
# Generate with: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
DASHBOARD_PASSWORD_HASH=

# Upstash Redis (for login rate limiting). Required in production.
# Free tier: https://console.upstash.com — create a Regional DB in us-east-1.
# If both are empty in local dev, rate-limit.ts fails open and warns once on cold start.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Google Sheets (Plan 02) ===

# Service account email — *@*.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# PEM private key with literal \n (NOT real newlines). Wrap value in quotes.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Spreadsheet IDs (the long string in the Sheet URL between /d/ and /edit).
GOOGLE_SHEETS_TRANSACTIONS_ID=
GOOGLE_SHEETS_PAYOUTS_ID=
